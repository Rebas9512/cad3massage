# Base URL of the running API (no trailing slash). Default targets `wrangler dev`.
# NB: must be API_BASE_URL, not BASE_URL (Vitest reserves BASE_URL for its base path).
API_BASE_URL=http://127.0.0.1:8787

# Optional: seed staff credentials to exercise AUTH-02 / STAFF-* (else those stay pending).
STAFF_EMAIL=
STAFF_PASSWORD=
