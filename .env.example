# Local dev. Copy to .env (already created for local).
DATABASE_URL=postgres://cad3:cad3@127.0.0.1:5432/cad3
# Where the API listens (acceptance harness defaults to this).
API_PORT=8787
# Studio timezone — never rely on server local time.
STUDIO_TZ=America/Chicago
# Dev-only JWT secret. In prod this is a Workers secret (`wrangler secret put
# JWT_SECRET`, strong random) — the backend refuses to start on this dev default
# once a CORS allowlist (i.e. prod domains) is configured.
JWT_SECRET=dev-only-change-me
# Seed staff login (acceptance AUTH-02b uses these too). These values are what
# `npm run seed` writes; point DATABASE_URL at Neon to seed the prod DB.
STAFF_EMAIL=staff@example.com
STAFF_PASSWORD=change-me-locally
# Web dev server → API base.
VITE_API_BASE=http://127.0.0.1:8787

# --- Email notifications (Resend) ---
# API key from Resend → API keys. Never commit the real value.
RESEND_API_KEY=re_xxx
# Verified sending identity (domain verified in Resend). One-way / no-reply.
EMAIL_FROM=CAD3 Massage <noreply@cad3massage.com>
# false → don't actually send (logs to console + records in DB); true → real Resend sends.
EMAIL_ENABLED=false
# Inbox that receives staff alerts (new booking / cancellation). Prod value lives
# in wrangler.toml [vars]; this is just the local-dev default.
STAFF_NOTIFY_EMAIL=alerts@example.com
# Public app base URL — used to build "manage booking" links in emails.
APP_BASE_URL=http://127.0.0.1:5173

# --- WeChat staff push (PushPlus, secondary staff-alert channel) ---
# Token from pushplus.plus (requires real-name auth). PII-free nudge only.
PUSHPLUS_TOKEN=
# false → console (no real push); true (+ token) → real PushPlus → personal WeChat.
WECHAT_ENABLED=false
