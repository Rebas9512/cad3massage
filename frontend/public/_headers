# Cloudflare Pages cache policy.
# Entry HTML + service worker must always be revalidated so a new deploy is seen
# immediately (otherwise a stale index.html/sw.js keeps a device on the old build).
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/sw.js
  Cache-Control: public, max-age=0, must-revalidate
/manifest.webmanifest
  Cache-Control: public, max-age=0, must-revalidate

# Hashed, content-addressed build assets never change → cache hard & immutable.
/assets/*
  Cache-Control: public, max-age=31536000, immutable
